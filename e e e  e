local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Configuration Variables
getgenv().AimbotEnabled = false
getgenv().AimbotKey = Enum.UserInputType.MouseButton2 -- Right Click
getgenv().Smoothing = 0.5 -- Higher = Slower/Smoother
getgenv().AimbotPart = "Head" -- Head, UpperTorso, HumanoidRootPart

local function getClosestPlayer()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(getgenv().AimbotPart) then
            local targetPart = player.Character[getgenv().AimbotPart]
            local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)

            if onScreen then
                local distance = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if distance < shortestDistance then
                    closestPlayer = player
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

RunService.RenderStepped:Connect(function()
    if getgenv().AimbotEnabled and UserInputService:IsMouseButtonPressed(getgenv().AimbotKey) then
        local target = getClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild(getgenv().AimbotPart) then
            local targetPos = target.Character[getgenv().AimbotPart].Position
            local currentCFrame = Camera.CFrame
            
            local targetCFrame = CFrame.new(currentCFrame.Position, targetPos)
            Camera.CFrame = currentCFrame:Lerp(targetCFrame, getgenv().Smoothing)
        end
    end
end)

